# ====================================================================
#  PLANTILLA de variables de entorno (SECRETOS)
# --------------------------------------------------------------------
#  1) Copia este archivo y renómbralo a  ".env"  (sin .example)
#  2) Rellena los valores reales
#  3) El archivo .env NUNCA se sube a GitHub (lo bloquea .gitignore)
#
#  En Vercel: configura estas mismas variables en
#  Settings -> Environment Variables
# ====================================================================

# Tu clave secreta de Dapta (x-api-key)
DAPTA_API_KEY=pega-aqui-tu-clave

# URL del webhook SIN el "?x-api-key=..." al final
DAPTA_URL=https://api.dapta.ai/api/cegruizgmailcom-173-176-8/kuyay-future-reservations-source

# ---- Máquina de efectivo del kiosko (opcional) ----
# Túnel ngrok que apunta a la máquina de efectivo local
KIOSK_BASE_URL=https://tu-tunel.ngrok-free.dev
# Llave para que la app hable con la máquina
KIOSK_API_KEY=pega-aqui-la-api-key-del-kiosko
# Secreto compartido para verificar la firma del webhook de resultado
KIOSK_WEBHOOK_SECRET=pega-aqui-el-webhook-secret

# ---- Reporte de pagos a Dapta ----
DAPTA_REPORT_URL=https://api.dapta.ai/api/ded48f01966e5dc9/kuyay-report-payment
DAPTA_REPORT_API_KEY=pega-aqui-la-api-key-del-reporte
